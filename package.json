{
  "name": "alin",
  "version": "0.0.1",
  "description": "Turn a multi-hour API integration into a single command",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "alin": "./dist/index.js"
  },
  "scripts": {
